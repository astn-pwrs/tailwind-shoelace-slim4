<!DOCTYPE html>
<html lang="ja" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <title>SPA Layout</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body class="h-full overflow-hidden">
    <div class="flex flex-col h-full">
      <!-- Header -->
      <header class="h-10 bg-success flex items-center justify-center">
        ヘッダー
      </header>

      <!-- Main Content -->
      <main class="flex-1 overflow-hidden">
        <div class="h-full overflow-y-auto p-4">
          <div class="max-w-4xl mx-auto space-y-4">
            <!-- スクロールするコンテンツ -->
            <div class="h-37.5 p-4 rounded shadow">
              長いコンテンツがここに入ります。スクロールして確認してね。
            </div>
          </div>
        </div>
      </main>

      <!-- Footer -->
      <footer class="h-12 bg-gray-800 text-white flex items-center justify-center">
        フッター
      </footer>
    </div>
  </body>
</html>
